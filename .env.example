# gulfvista.properties Environment Configuration
# Phase 5: Reelly API Integration & Lead Management
# Copy this file to .env and fill in your actual values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# NOTE: If password contains special characters like @, #, :, /, encode them:
# @ = %40, # = %23, : = %3A, / = %2F
# Example: password "mypass@123" becomes "mypass%40123"
DATABASE_URL=postgresql+psycopg://postgres:your_password@localhost:5432/gulfvista_dev

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# JWT Secret Key - Change this in production!
SECRET_KEY=your-super-secret-jwt-key-change-in-production-to-random-string

# ============================================================================
# STRIPE INTEGRATION (Payment Processing)
# ============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ============================================================================
# REELLY API INTEGRATION (Property Data Source)
# ============================================================================
# API credentials from Reelly dashboard
REELLY_API_KEY=your_reelly_api_key
REELLY_BASE_URL=https://api.reelly.io/v1

# Webhook signature verification
# This secret is used to verify incoming Reelly webhooks using HMAC-SHA256
REELLY_WEBHOOK_SECRET=your_reelly_webhook_secret

# Sync configuration
REELLY_SYNC_INTERVAL_MINUTES=60          # Sync properties every 60 minutes
REELLY_BATCH_SIZE=50                      # Process 50 properties per batch
REELLY_TIMEOUT_SECONDS=30                 # API request timeout
REELLY_MAX_RETRIES=3                      # Retry failed requests 3 times

# ============================================================================
# BACKGROUND JOBS CONFIGURATION (Phase 5)
# ============================================================================
# Enable/disable background job scheduler
SCHEDULER_ENABLED=true

# Individual job toggles
PROPERTY_SYNC_JOB_ENABLED=true            # Sync properties from Reelly
LEAD_NOTIFICATIONS_JOB_ENABLED=true       # Send agent notifications for pending leads
AGENT_STATS_JOB_ENABLED=true              # Update agent performance statistics

# ============================================================================
# PROPERTY SYNC SETTINGS
# ============================================================================
# Batch processing for memory efficiency
PROPERTY_SYNC_BATCH_SIZE=50

# Timeout for sync operations
PROPERTY_SYNC_TIMEOUT_SECONDS=300         # 5 minutes

# Full refresh interval (re-sync all properties)
SYNC_FULL_REFRESH_DAYS=7                  # Full sync every 7 days

# ============================================================================
# LEAD MANAGEMENT SETTINGS
# ============================================================================
# Auto-assignment of leads to agents
LEAD_AUTO_ASSIGN_ENABLED=true             # Enable round-robin auto-assignment

# Notification frequency
LEAD_NOTIFICATION_INTERVAL_MINUTES=5      # Check and notify every 5 minutes
LEAD_NOTIFICATION_THRESHOLD_MINUTES=30    # Notify agents about leads created 30+ min ago

# Follow-up reminders
LEAD_FOLLOW_UP_REMINDER_HOURS=24          # Remind agents to follow up after 24 hours

# ============================================================================
# AGENT MANAGEMENT SETTINGS
# ============================================================================
# Agent verification workflow
AGENT_VERIFICATION_REQUIRED=true          # Require payment/verification before listing

# Statistics update interval
AGENT_STATS_RECALC_INTERVAL_HOURS=24      # Recalculate stats every 24 hours

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false

# App info
APP_NAME=gulfvista Real Estate API

# ============================================================================
# CORS CONFIGURATION (Allowed Origins)
# ============================================================================
# Frontend and development URLs
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000,http://127.0.0.1:5173,http://127.0.0.1:8000

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO                             # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=gulfvista.log                     # Log file path
LOG_TO_FILE=true                           # Write logs to file

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_PROPERTY_SYNC=true                  # Enable property syncing from Reelly
ENABLE_LEAD_AUTO_ASSIGNMENT=true           # Enable automatic lead assignment
ENABLE_WEBHOOK_VERIFICATION=true           # Verify Reelly webhook signatures
ENABLE_AGENT_VERIFICATION_WORKFLOW=true    # Require agent verification

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=development                    # development, staging, production
