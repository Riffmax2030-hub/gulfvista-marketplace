# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://gulfvista:secure_password_123@localhost:5432/gulfvista_dev

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# Secret key for JWT token signing
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production-never-hardcode

# ============================================================================
# STRIPE CONFIGURATION
# ============================================================================
# Get these from your Stripe dashboard (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================================================
# REELLY API CONFIGURATION
# ============================================================================
# Obtain API key from Reelly (https://reelly.io)
REELLY_API_KEY=your_reelly_api_key
REELLY_BASE_URL=https://api.reelly.io/v1

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
DEBUG=False
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
