{
  "build": {
    "builder": "dockerfile",
    "dockerfile": "./backend/Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "port": 8000,
    "startCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT"
  },
  "volumes": [
    {
      "mountPath": "/app/gulfvista.log",
      "name": "logs"
    }
  ]
}
